# LaxmiPay — environment configuration
# Copy this file to .env and fill in real values before running.
# Never commit .env to version control.

# ── API server ──────────────────────────────────────────────
DB_PATH=./Database.db

# Secret key for signing JWT tokens — use a long random string in production
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# JWT token expiry in minutes (default 480 = 8 hours)
JWT_EXPIRE_MINUTES=480

# ── Admin credentials ────────────────────────────────────────
ADMIN_USERNAME=admin

# Generate bcrypt hash by running: python sm.py  (it prompts you)
# Then paste the output here:
ADMIN_PASSWORD_HASH=$2b$12$...paste_your_hash_here...

# ── ESP8266 API key ──────────────────────────────────────────
# Set the same key in your Arduino/ESP8266 sketch
ESP_API_KEY=esp-secret-key-change-me

# ── CORS ─────────────────────────────────────────────────────
# Set to your Streamlit URL in production (e.g. http://localhost:8501)
# Use * only for local development
ALLOWED_ORIGIN=http://localhost:8501

# ── Fraud detection thresholds ───────────────────────────────
FRAUD_VELOCITY_LIMIT=5       # max debit transactions per 60 seconds per card
FRAUD_AMOUNT_THRESHOLD=2000  # single transaction amount (₹) that triggers flag

# ── Streamlit app ────────────────────────────────────────────
API_URL=http://localhost:8000
